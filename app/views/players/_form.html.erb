<%= form_with model: player do |form| %>
    <% if form.object.errors.any? %>
        <p class="error"><%= form.object.errors.full_messages.first %></p>
    <% end %>

    <div>
        <%= form.label :name %>
        <%= form.text_field :name %>
    </div>

    <div>
        <%= form.label :age %>
        <%= form.number_field :age %>
    </div>

    <div>
        <%= form.label :email %>
        <%= form.email_field :email %>
    </div>

    <div>
        <%= form.label :phone %>
        <%= form.text_field :phone %>
    </div>

    <div>
        <%= form.submit %>
    </div>
<% end %>
